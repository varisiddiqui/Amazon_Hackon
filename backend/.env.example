# Copy to backend/.env for local dev
# On Vercel: add these in Project → Settings → Environment Variables

PORT=5001
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-to-a-long-random-secret
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/campusflow

# AWS (optional)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=campusflow-uploads
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# Google Gemini AI (optional)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Firebase (also add VITE_FIREBASE_* in root for frontend build)
# VITE_FIREBASE_* vars go in Vercel for frontend build
